#!/bin/sh
# postinst — mahjong-mitm 装包后置脚本
#
# 1. 生成每台路由器独立的自签证书（游戏 VERIFYPEER=0，CN/SAN 不校验，
#    用 openssl 一行生成即可，省掉 Python cryptography 依赖）。
# 2. enable + start 服务。
#
# 证书落点必须与 setup_mitm.run() 的默认 cert_dir 一致：
#   _RUNTIME_ROOT/data/mitm/  其中 _RUNTIME_ROOT = /usr/lib/mahjong-mitm

PROG_DIR="/usr/lib/mahjong-mitm"
CERT_DIR="$PROG_DIR/data/mitm"
CERT="$CERT_DIR/mitm_cert.pem"
KEY="$CERT_DIR/mitm_key.pem"

[ -n "${IPKG_INSTROOT}" ] && exit 0  # 仅在目标设备上跑，imagebuilder 构建时跳过

mkdir -p "$CERT_DIR"

if [ ! -f "$CERT" ] || [ ! -f "$KEY" ]; then
	if command -v openssl >/dev/null 2>&1; then
		openssl req -x509 -newkey rsa:2048 -nodes \
			-keyout "$KEY" -out "$CERT" -days 3650 \
			-subj "/CN=gxb.hzxuanming.com" >/dev/null 2>&1
		echo "mahjong-mitm: generated self-signed cert at $CERT"
	else
		echo "mahjong-mitm: openssl not found; cert will be auto-generated by Python (needs python3-cryptography)" >&2
	fi
fi

# 启用开机自启 + 立即启动
/etc/init.d/mahjong-mitm enable 2>/dev/null
/etc/init.d/mahjong-mitm start 2>/dev/null

exit 0
