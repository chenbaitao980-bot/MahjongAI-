#!/usr/bin/env python3
# probe — environment readiness check for router MITM setup
# Usage: probe
# Exit 0 = ALL SYSTEMS GO, Exit 1 = NOT READY
import sys
import os
import socket
import subprocess

TAG = "[PROBE]"
results = []

def check(name, fn):
    try:
        msg = fn()
        print(f"{TAG} PASS  {name}" + (f" ({msg})" if msg else ""))
        results.append(True)
    except Exception as e:
        print(f"{TAG} FAIL  {name} — {e}")
        results.append(False)

# 1. python3 version >= 3.8
def chk_python():
    v = sys.version_info
    if v < (3, 8):
        raise RuntimeError(f"{v.major}.{v.minor} < 3.8")
    return f"{v.major}.{v.minor}.{v.micro}"
check("python3 >= 3.8", chk_python)

# 2. ssl module (python3-openssl)
def chk_ssl():
    import ssl
    return ssl.OPENSSL_VERSION
check("python3 ssl module", chk_ssl)

# 3. urllib.request (python3-urllib)
def chk_urllib():
    import urllib.request
    return None
check("python3 urllib module", chk_urllib)

# 4. openssl CLI
def chk_openssl_cli():
    r = subprocess.run(["openssl", "version"], capture_output=True, text=True, timeout=5)
    if r.returncode != 0:
        raise RuntimeError("non-zero exit")
    return r.stdout.strip()
check("openssl CLI", chk_openssl_cli)

# 5. fw4 or nftables available
def chk_nft():
    for cmd in [["fw4", "-v"], ["nft", "--version"]]:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=5)
        if r.returncode == 0:
            return (r.stdout + r.stderr).strip().splitlines()[0]
    raise RuntimeError("neither fw4 nor nft found")
check("fw4 / nftables", chk_nft)

# 6. port 443 bindable
def chk_port_443():
    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    try:
        s.bind(("0.0.0.0", 443))
    finally:
        s.close()
    return "0.0.0.0:443"
check("port 443 bindable", chk_port_443)

# 7. port 5353 bindable
def chk_port_5353():
    s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    try:
        s.bind(("0.0.0.0", 5353))
    finally:
        s.close()
    return "0.0.0.0:5353"
check("port 5353 bindable", chk_port_5353)

# 8. procd / rc.common present
def chk_procd():
    if not os.path.exists("/etc/rc.common"):
        raise RuntimeError("/etc/rc.common not found")
    r = subprocess.run(["pgrep", "procd"], capture_output=True, timeout=5)
    if r.returncode != 0:
        raise RuntimeError("procd process not running")
    return "procd running"
check("procd running", chk_procd)

# 9. disk space >= 50 MB free on /
def chk_disk():
    st = os.statvfs("/")
    free_mb = st.f_bavail * st.f_frsize // (1024 * 1024)
    if free_mb < 50:
        raise RuntimeError(f"only {free_mb} MB free (need >= 50)")
    return f"{free_mb} MB free"
check("disk >= 50 MB", chk_disk)

# 10. RAM >= 64 MB free
def chk_ram():
    with open("/proc/meminfo") as f:
        for line in f:
            if line.startswith("MemAvailable:"):
                kb = int(line.split()[1])
                mb = kb // 1024
                if mb < 64:
                    raise RuntimeError(f"only {mb} MB available (need >= 64)")
                return f"{mb} MB available"
    raise RuntimeError("could not read /proc/meminfo")
check("RAM >= 64 MB", chk_ram)

# Summary
passed = sum(results)
total = len(results)
print(f"{TAG} PASS: {passed}/{total}  FAIL: {total - passed}/{total}")
if all(results):
    print(f"{TAG} ALL SYSTEMS GO")
    sys.exit(0)
else:
    print(f"{TAG} NOT READY")
    sys.exit(1)
